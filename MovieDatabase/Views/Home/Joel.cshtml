@*
    Home/Joel.cshtml - The "Get to Know Joel" page.
    Provides a short bio of Joel Hilton along with external links
    to his comedy group (Quick Wits) and his podcast (Baconsale).
*@

@{
    ViewData["Title"] = "Get to Know Joel";
}

<div class="text-center">
    @* Page heading *@
    <h1 class="display-4 mb-4">Get to Know Joel</h1>

    @* Brief description of Joel *@
    <p class="lead">
        Joel Hilton loves movies, comedy, and talking about both.
    </p>

    @* External link to Joel's comedy improv group website *@
