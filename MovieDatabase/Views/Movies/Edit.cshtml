@model MovieDatabase.Models.Movie

@{
    ViewData["Title"] = "Edit Movie";
}

<!-- Edit Movie form: lets the user update details for an existing movie -->
<div class="page-card">
    <h1 class="mb-4">Edit Movie</h1>

    <form asp-action="Edit" method="post" class="needs-validation" novalidate>
    <!-- Hidden field to pass the movie ID back with the form -->
    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <!-- Category dropdown — pre-selects the movie's current category -->
    <div class="mb-3">
        <label asp-for="CategoryId" class="form-label">Category</label>
        <select asp-for="CategoryId" class="form-select">
            <option value="">-- Select Category --</option>
            @foreach (var cat in (IEnumerable<MovieDatabase.Models.Category>)ViewBag.Categories)
            {
                <option value="@cat.CategoryId">@cat.Name</option>
            }
        </select>
        <span asp-validation-for="CategoryId" class="text-danger"></span>
    </div>

    <!-- Movie title -->
    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <!-- Release year -->
    <div class="mb-3">
        <label asp-for="Year" class="form-label"></label>
        <input asp-for="Year" class="form-control" />
        <span asp-validation-for="Year" class="text-danger"></span>
    </div>

    <!-- Director name -->
    <div class="mb-3">
        <label asp-for="Director" class="form-label"></label>
        <input asp-for="Director" class="form-control" />
        <span asp-validation-for="Director" class="text-danger"></span>
    </div>

    <!-- MPAA rating dropdown -->
    <div class="mb-3">
        <label asp-for="Rating" class="form-label"></label>
        <select asp-for="Rating" class="form-select">
            <option value="">-- Select Rating --</option>
            <option value="G">G</option>
            <option value="PG">PG</option>
            <option value="PG-13">PG-13</option>
            <option value="R">R</option>
        </select>
        <span asp-validation-for="Rating" class="text-danger"></span>
    </div>

    <!-- Whether the movie has been edited for content -->
    <div class="mb-3">
        <label asp-for="Edited" class="form-label">Edited</label>
        <select asp-for="Edited" class="form-select">
            <option value="">-- Select --</option>
            <option value="true">Yes</option>
            <option value="false">No</option>
        </select>
        <span asp-validation-for="Edited" class="text-danger"></span>
    </div>

    <!-- Optional: who the movie is lent to -->
    <div class="mb-3">
        <label asp-for="LentTo" class="form-label"></label>
        <input asp-for="LentTo" class="form-control" />
        <span asp-validation-for="LentTo" class="text-danger"></span>
    </div>

    <!-- Optional short notes (max 25 chars) -->
    <div class="mb-3">
        <label asp-for="Notes" class="form-label"></label>
        <input asp-for="Notes" class="form-control" maxlength="25" />
        <span asp-validation-for="Notes" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary me-2">Save Changes</button>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

