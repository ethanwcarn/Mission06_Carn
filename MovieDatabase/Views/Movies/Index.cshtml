@model IEnumerable<MovieDatabase.Models.Movie>

@{
    ViewData["Title"] = "Movie Collection";
}

<!-- Main movie listing page showing every movie in the database -->
<div class="card page-card border-0">
    <div class="card-body p-4">
        <h1 class="mb-4">Joel Hilton Movie Collection</h1>

        <!-- Link to the Add Movie form -->
        <p>
            <a asp-action="Add" class="btn btn-primary">Add New Movie</a>
        </p>

        <!-- Responsive table listing all movies with Edit/Delete actions -->
        <div class="table-responsive">
            <table class="table table-striped table-hover table-bordered">
                <thead class="table-dark">
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Year</th>
                        <th>Director</th>
                        <th>Rating</th>
                        <th>Edited</th>
                        <th>Lent To</th>
                        <th>Notes</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @* Loop through each movie and display its details in a row *@
                    @foreach (var movie in Model)
                    {
                        <tr>
                            <td>@movie.Title</td>
                            <!-- Display the related Category name via the navigation property -->
                            <td>@movie.Category?.Name</td>
                            <td>@movie.Year</td>
                            <td>@movie.Director</td>
                            <td>@movie.Rating</td>
                            <td>@(movie.Edited.HasValue ? (movie.Edited.Value ? "Yes" : "No") : "")</td>
                            <td>@movie.LentTo</td>
                            <td>@movie.Notes</td>
                            <td class="text-nowrap">
                                <!-- Edit and Delete action links for each movie -->
                                <a asp-action="Edit" asp-route-id="@movie.Id" class="btn btn-sm btn-outline-secondary me-1">Edit</a>
                                <a asp-action="Delete" asp-route-id="@movie.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

