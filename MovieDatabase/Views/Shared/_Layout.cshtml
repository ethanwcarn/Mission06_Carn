@*
    _Layout.cshtml - Shared layout template used by every page in the application.
    Contains the HTML structure, navigation menu, footer, and script/stylesheet references.
    Individual views are rendered inside this layout via @RenderBody().
*@
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    @* Page title is set dynamically by each view using ViewData["Title"] *@
    <title>@ViewData["Title"] - MovieDatabase</title>
    <script type="importmap"></script>
    @* Bootstrap CSS for responsive layout and UI components *@
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    @* Custom site-wide styles *@
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @* Scoped CSS generated by the build (for component-level styles) *@
    <link rel="stylesheet" href="~/MovieDatabase.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        @* Shared navigation bar - displayed on every page across the application *@
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                @* Brand link - clicking the site name returns to the home page *@
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">The Joel Hilton Film Collection</a>
                @* Hamburger toggle button for mobile/small screen navigation *@
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                @* Navigation links - shared across all views *@
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @* Link to the Home page *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        @* Link to the "Get to Know Joel" page *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Joel">Get to Know Joel</a>
                        </li>
                        @* Link to the Add Movie form *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Movies" asp-action="Add">Add Movie</a>
                        </li>
                        @* Link to the full Movie List view *@
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Movies" asp-action="Index">Movie List</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @* Main content area - each view's content is injected here via @RenderBody() *@
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @* Footer displayed at the bottom of every page *@
    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - The Joel Hilton Film Collection
        </div>
    </footer>

    @* jQuery library - required by Bootstrap and jQuery Validation *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @* Bootstrap JavaScript bundle for interactive UI components (navbar toggle, etc.) *@
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @* Custom site-wide JavaScript *@
    <script src="~/js/site.js" asp-append-version="true"></script>
    @* Optional Scripts section - views can inject additional scripts (e.g., validation) here *@
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
