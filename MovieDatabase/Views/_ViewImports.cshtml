@* _ViewImports.cshtml - Shared imports applied to every Razor view in the application. *@

@* Import the root namespace so views can reference project types *@
@using MovieDatabase

@* Import the Models namespace so views can reference Movie, MovieContext, etc. without full qualification *@
@using MovieDatabase.Models

@* Enable Tag Helpers (asp-for, asp-action, asp-controller, etc.) in all views *@
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
